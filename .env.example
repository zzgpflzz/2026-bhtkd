# ────────────────────────────────────────────────
# Firebase Admin SDK 환경변수 (서버 전용, 절대 클라이언트 노출 금지)
# 이 파일은 템플릿이고, 실제 값은 .env.local 에 넣어 주세요.
# ────────────────────────────────────────────────

# 권장: Firebase Console에서 받은 service-account JSON 파일을
# base64로 인코딩한 한 줄 문자열을 넣습니다.
#
# macOS/Linux 인코딩 명령:
#   base64 -i ~/Downloads/your-service-account.json | tr -d '\n' | pbcopy
# (위 명령 후 클립보드에 복사된 값을 아래 따옴표 안에 붙여넣기)
FIREBASE_SERVICE_ACCOUNT_BASE64="여기에_base64_인코딩된_문자열_붙여넣기"

# 대안: base64 안 쓰고 JSON 원본을 그대로 넣고 싶을 때
# (Vercel 대시보드는 줄바꿈 있는 값을 그대로 받기 때문에 이 방식도 OK)
# FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"bhtkd-37f39", ...}'

# ────────────────────────────────────────────────
# (선택) Vercel Blob Storage
# Vercel 대시보드에서 Blob Storage 활성화 시 자동 설정됨
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
# ────────────────────────────────────────────────
